# ─────────────────────────────────────────────────────────────────────────────
# A-List Fastlane Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Setup (one time):
#   gem install fastlane
#   cp fastlane/.env.fastlane.example fastlane/.env.fastlane
#   # Fill in your credentials in .env.fastlane
#
# Deploy to TestFlight:
#   fastlane beta
#
# Deploy to App Store:
#   fastlane release
# ─────────────────────────────────────────────────────────────────────────────

default_platform(:ios)

# ── Constants ─────────────────────────────────────────────────────────────────
WORKSPACE     = "ios/App/App.xcworkspace"
SCHEME        = "App"
APP_ID        = "com.alist.app"
PROJECT_ROOT  = File.expand_path("..", __dir__)

platform :ios do

  # ── Before all lanes ───────────────────────────────────────────────────────
  before_all do
    # Load .env.fastlane if present (local dev)
    Dotenv.overload(File.join(PROJECT_ROOT, "fastlane", ".env.fastlane"))
  end

  # ── bump_build: increment build number from App Store Connect ─────────────
  private_lane :bump_build do
    increment_build_number(
      build_number: app_store_build_number(
        live: false,
        app_identifier: APP_ID
      ) + 1,
      xcodeproj: "ios/App/App.xcodeproj"
    )
  end

  # ── web_build: build the Vite frontend and sync to Capacitor ──────────────
  private_lane :web_build do
    UI.message "Building web assets..."
    sh("cd #{PROJECT_ROOT} && npm run build")
    UI.message "Syncing Capacitor..."
    sh("cd #{PROJECT_ROOT} && npx cap sync ios")
  end

  # ── certs: fetch/create signing certs via match ───────────────────────────
  private_lane :certs do |options|
    type = options[:type] || "appstore"
    match(
      type: type,
      app_identifier: APP_ID,
      git_url: ENV["MATCH_GIT_URL"],          # private certs repo
      readonly: ENV["CI"] ? true : false,      # readonly on CI
      keychain_name: ENV["MATCH_KEYCHAIN_NAME"] || "login",
      keychain_password: ENV["MATCH_KEYCHAIN_PASSWORD"] || ""
    )
  end

  # ── beta: build + upload to TestFlight ────────────────────────────────────
  desc "Build and upload a new TestFlight beta"
  lane :beta do
    web_build
    bump_build
    certs(type: "appstore")

    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "#{PROJECT_ROOT}/build",
      output_name: "AList.ipa",
      clean: true,
      export_options: {
        provisioningProfiles: {
          APP_ID => "match AppStore #{APP_ID}"
        }
      }
    )

    upload_to_testflight(
      ipa: "#{PROJECT_ROOT}/build/AList.ipa",
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false,
      changelog: changelog_entry
    )

    UI.success "✅ TestFlight build uploaded!"
    notify_slack("Beta uploaded to TestFlight") if ENV["SLACK_URL"]
  end

  # ── release: build + submit to App Store ──────────────────────────────────
  desc "Build and submit to App Store for review"
  lane :release do
    web_build
    bump_build
    certs(type: "appstore")

    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "#{PROJECT_ROOT}/build",
      output_name: "AList.ipa",
      clean: true,
      export_options: {
        provisioningProfiles: {
          APP_ID => "match AppStore #{APP_ID}"
        }
      }
    )

    upload_to_app_store(
      ipa: "#{PROJECT_ROOT}/build/AList.ipa",
      skip_screenshots: true,
      skip_metadata: false,
      submit_for_review: false,   # set true when ready to submit
      automatic_release: false
    )

    UI.success "✅ Uploaded to App Store — submit for review in App Store Connect."
  end

  # ── screenshots: generate App Store screenshots ───────────────────────────
  desc "Generate App Store screenshots"
  lane :screenshots do
    capture_screenshots(
      workspace: WORKSPACE,
      scheme: SCHEME
    )
    frame_screenshots(white: false)
  end

  # ── certs_renew: refresh Match certificates ────────────────────────────────
  desc "Renew and sync certificates"
  lane :certs_renew do
    match(
      type: "appstore",
      app_identifier: APP_ID,
      git_url: ENV["MATCH_GIT_URL"],
      force_for_new_devices: true
    )
  end

  # ── Helpers ────────────────────────────────────────────────────────────────
  def changelog_entry
    # Pull last git commit message as changelog
    `git log -1 --pretty=%B`.strip.slice(0, 200)
  rescue
    "A-List beta build"
  end

  def notify_slack(message)
    slack(
      message: message,
      slack_url: ENV["SLACK_URL"],
      success: true,
      default_payloads: [:git_branch, :git_author, :last_git_commit]
    )
  rescue
    UI.message "Slack notification skipped (no webhook configured)"
  end

  # ── Error handler ──────────────────────────────────────────────────────────
  error do |lane, exception|
    UI.error "Lane #{lane} failed: #{exception.message}"
    notify_slack("❌ #{lane} failed: #{exception.message}") if ENV["SLACK_URL"]
  end

end
