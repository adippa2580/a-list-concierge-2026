# ─────────────────────────────────────────────────────────────────────────────
# A-List Fastlane Environment Variables
# Copy this file to .env.fastlane and fill in your values.
# .env.fastlane is gitignored — never commit credentials.
# ─────────────────────────────────────────────────────────────────────────────

# Apple Developer credentials
APPLE_ID=your@email.com
APPLE_TEAM_ID=XXXXXXXXXX          # 10-char Team ID from developer.apple.com
ITC_TEAM_ID=XXXXXXXXX             # Numeric team ID from App Store Connect

# Fastlane Match — private Git repo for storing encrypted certs + profiles
# Create a new private GitHub repo (e.g. github.com/adippa2580/alist-certs)
MATCH_GIT_URL=https://github.com/adippa2580/alist-certs.git
MATCH_PASSWORD=your_match_password # encryption passphrase for the certs repo

# Keychain (leave as defaults for local dev)
MATCH_KEYCHAIN_NAME=login
MATCH_KEYCHAIN_PASSWORD=

# App Store Connect API Key (recommended over password auth)
# Generate at: appstoreconnect.apple.com → Users → Keys
APP_STORE_CONNECT_API_KEY_ID=XXXXXXXXXX
APP_STORE_CONNECT_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
APP_STORE_CONNECT_KEY_FILEPATH=~/.appstoreconnect/AuthKey_XXXXXXXXXX.p8

# Optional: Slack webhook for build notifications
# SLACK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
