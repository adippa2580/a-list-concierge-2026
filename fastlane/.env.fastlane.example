# Copy this file to .env.fastlane and fill in your values
# .env.fastlane is gitignored — never commit it

# Apple credentials
APPLE_ID=adippa@dippa.com.au
APPLE_TEAM_ID=           # 10-char string from developer.apple.com/account → Membership
ITC_TEAM_ID=             # Numeric ID from App Store Connect → Users & Access → your team

# Match (cert storage)
MATCH_GIT_URL=https://github.com/adippa2580/alist-certs.git
MATCH_PASSWORD=          # Strong password — encrypts certs in the repo
MATCH_KEYCHAIN_NAME=login
MATCH_KEYCHAIN_PASSWORD=

# App Store Connect API Key (optional but recommended — avoids 2FA prompts)
# Create at: appstoreconnect.apple.com/access/integrations/api → Generate API Key
APP_STORE_CONNECT_API_KEY_ID=       # e.g. ABC1234567
APP_STORE_CONNECT_ISSUER_ID=        # UUID from the same page
APP_STORE_CONNECT_KEY_FILEPATH=     # absolute path to downloaded .p8 file
                                    # e.g. /Users/adpspare/Downloads/AuthKey_ABC1234567.p8
